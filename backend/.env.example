# App
NODE_ENV=development
PORT=3000
API_VERSION=v1
ALLOWED_ORIGINS=http://localhost:3001,exp://localhost:8081

# Database
DATABASE_URL=postgresql://lovrhub:secret@localhost:5432/lovrhub?schema=public
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=lovrhub:

# JWT
JWT_ACCESS_SECRET=change-this-to-a-256-bit-random-secret-for-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=change-this-to-a-different-256-bit-secret-for-production
JWT_REFRESH_EXPIRY=30d

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=lovrhub-media-dev
AWS_CLOUDFRONT_DOMAIN=https://cdn.lovrhub.com
AWS_SES_FROM_EMAIL=no-reply@lovrhub.com

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
STRIPE_PREMIUM_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_PREMIUM_PLUS_PRICE_ID=price_xxxxxxxxxxxxx

# Sentry
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# OTP
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
